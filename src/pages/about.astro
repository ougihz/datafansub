---
import "../styles/global.css";
import "../styles/about.css";
import { fetchData } from "../lib/datafansub";

const { entries, fansubs } = await fetchData();
const fansubsConLinks = new Set<string>();
entries.forEach((entry) => {
  if (entry.nyaa || entry.nekobt) {
    entry.fansub.forEach((fId) => fansubsConLinks.add(fId));
  }
});

const countMap = new Map<string, number>();
entries.forEach((entry) => {
  entry.fansub.forEach((id) => {
    if (fansubsConLinks.has(id)) {
      countMap.set(id, (countMap.get(id) ?? 0) + 1);
    }
  });
});

const fansubEntryCount = Array.from(countMap.entries())
  .map(([id, count]) => {
    const fansub = fansubs.find((f) => f.id === id);
    return {
      id,
      name: fansub?.name ?? "Desconocido",
      website: fansub?.website ?? null,
      count,
    };
  })
  .filter((f) => f.name !== "Desconocido")
  .sort((a, b) => b.count - a.count);
