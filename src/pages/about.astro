                        href={f.website}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="link-style"
                      >
                        {f.name}
                      </a>
                    ) : (
                      f.name
                    )}
                  </td>
                  <td style="text-align: right;">{f.count}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
