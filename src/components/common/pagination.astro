<div
  id="paginationControls"
  class="pagination-controls"
  style="margin-top: 1rem; text-align: center; display: flex; justify-content: center; align-items: center; gap: 0.5rem;"
>
  <button
    id="prevPageBtn"
    aria-label="Página anterior"
    disabled
    style="font-size: 1.2rem; padding: 0 0.6rem; cursor: pointer;"
    >&#171;</button
  >
  <input
    id="pageInput"
    type="number"
    min="1"
    value="1"
    aria-label="Número de página"
    style="width: 3.5rem; text-align: center; font-size: 1rem; border-radius: 3px; border: 1.5px solid #aaa; background: transparent; color: inherit;"
  />
  <span
    id="pageInfo"
    style="min-width: 90px; display: inline-block; text-align: left; font-size: 0.9rem; user-select: none;"
    >Página 1</span
  >
  <button
    id="nextPageBtn"
    aria-label="Página siguiente"
    disabled
    style="font-size: 1.2rem; padding: 0 0.6rem; cursor: pointer;"
    >&#187;</button
  >
</div>
